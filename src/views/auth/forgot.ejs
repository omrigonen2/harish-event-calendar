<% layout('layouts/auth') -%>
<h1 class="auth__title"><%= t('auth.forgotTitle') %></h1>
<p class="muted"><%= t('auth.forgotIntro') %></p>
<form method="post" action="/forgot" class="form">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
  <label class="field">
    <span><%= t('auth.email') %></span>
    <input type="email" name="email" required autocomplete="email" autofocus>
  </label>
  <button class="btn btn--primary btn--block" type="submit"><%= t('auth.sendReset') %></button>
</form>
<p class="auth__alt"><a href="/login"><%= t('auth.backToSignIn') %></a></p>
