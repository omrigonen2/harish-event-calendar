<% layout('layouts/admin') -%>
<%
  const b = `/admin/${tenant.slug}`;
  const supported = tenantSettings.supportedLanguages || [];
  const def = tenantSettings.defaultLanguage;
  const others = supported.filter((c) => c !== def);
%>
<div class="page-head">
  <h1><%= t('categories.title') %></h1>
  <span class="muted sm"><%= t('taxonomy.dragHint') %></span>
</div>

<%- include('../partials/taxonomy-manager', {
  items: categories,
  kind: 'category',
  b,
  supported,
  def,
  others,
  hasColor: true,
  addTitle: t('categories.add'),
  allTitle: t('categories.all'),
  noYet: t('categories.noYet'),
  deleteConfirm: t('categories.deleteConfirm'),
}) %>
