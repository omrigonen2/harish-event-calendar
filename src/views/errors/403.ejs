<!doctype html>
<html lang="<%= typeof adminLang !== 'undefined' ? adminLang : 'he' %>" dir="<%= typeof adminDir !== 'undefined' ? adminDir : 'rtl' %>"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title><%= typeof t === 'function' ? t('errors.forbidden') : 'Forbidden' %></title><link rel="stylesheet" href="/css/app.css"></head>
<body class="error-page">
  <div class="error-box">
    <h1>403</h1>
    <p><%= typeof t === 'function' ? t('errors.forbiddenBody') : 'You do not have permission to access this resource.' %></p>
    <a class="btn btn--primary" href="/"><%= typeof t === 'function' ? t('errors.backHome') : 'Go home' %></a>
  </div>
</body></html>
