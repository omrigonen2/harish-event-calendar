<!doctype html>
<html lang="<%= typeof adminLang !== 'undefined' ? adminLang : 'he' %>" dir="<%= typeof adminDir !== 'undefined' ? adminDir : 'rtl' %>"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title><%= typeof t === 'function' ? t('errors.serverError') : 'Error' %></title><link rel="stylesheet" href="/css/app.css"></head>
<body class="error-page">
  <div class="error-box">
    <h1><%= typeof status !== 'undefined' ? status : 500 %></h1>
    <p><%= typeof t === 'function' ? t('errors.serverError') : 'Something went wrong.' %></p>
    <% if (typeof message !== 'undefined' && message) { %><p class="muted"><%= message %></p><% } %>
    <a class="btn btn--primary" href="/"><%= typeof t === 'function' ? t('errors.backHome') : 'Go home' %></a>
  </div>
</body></html>
